# Note: az acr build has bugs with trailing slashes - use ** patterns
# See: https://github.com/Azure/azure-cli/issues/31250

# Exclude virtual environment (use ** pattern for az acr build)
**/.venv
.venv

# Exclude development files
**/.vscode
**/.git
.vscode
.git
.gitignore
.gitattributes
test_*.py
**/tests
**/test_files
**/scripts

# Exclude Python cache (use ** pattern)
**/__pycache__
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
**/*.egg-info
**/dist
**/build
**/.eggs

# Exclude OS files
.DS_Store
**/.DS_Store
Thumbs.db
desktop.ini

# Exclude logs
*.log
**/logs

# Exclude temporary files
*.tmp
*.temp
**/.cache
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache

# Exclude Docker files (don't need these in the image)
Dockerfile
.dockerignore

# Exclude IDE files
*.swp
*.swo
*~
**/.idea

# Exclude documentation
**/docs
